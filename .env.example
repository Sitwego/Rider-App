# Sitwego Rider App — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# These are consumed at native build time via react-native-config.

# REST API base URL (dev tunnel or production host)
API_BASE_URL=https://<your-api-host>/

# gRPC server host (no scheme)
GRPC_HOST=<your-grpc-host>

# App environment: development | staging | production
APP_ENV=development

# Google Maps API key (Google Cloud Console). Written into AndroidManifest at prebuild.
GOOGLE_MAPS_API_KEY=AIza...
